<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Dashboard — <%= site.site_title %></title>
<link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<% const navActive = 'dashboard'; %>
<%- include('_nav') %>

<div class="container">
  <div class="page-header">
    <h1>Dashboard</h1>
    <a href="/admin/posts/new" class="btn btn-primary">+ New Post</a>
  </div>

  <div class="stats-grid">
    <div class="stat">
      <div class="label">Published</div>
      <div class="value"><%= stats.published %></div>
    </div>
    <div class="stat">
      <div class="label">Drafts</div>
      <div class="value"><%= stats.drafts %></div>
    </div>
    <div class="stat">
      <div class="label">Total Views</div>
      <div class="value"><%= Number(stats.total_views || 0).toLocaleString() %></div>
    </div>
    <div class="stat">
      <div class="label">Tags</div>
      <div class="value"><%= stats.total_tags %></div>
    </div>
  </div>

  <div class="two-col">
    <section class="card">
      <h2>Recent Posts</h2>
      <% if (recentPosts.length === 0) { %>
        <p class="text-muted">Belum ada post. <a href="/admin/posts/new">Buat sekarang →</a></p>
      <% } else { %>
        <ul class="simple-list">
          <% recentPosts.forEach(p => { %>
            <li>
              <a href="/admin/posts/<%= p.id %>/edit"><%= p.title %></a>
              <span class="badge <%= p.status %>"><%= p.status %></span>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </section>

    <section class="card">
      <h2>Top Posts</h2>
      <% if (topPosts.length === 0) { %>
        <p class="text-muted">No data yet.</p>
      <% } else { %>
        <ul class="simple-list">
          <% topPosts.forEach(p => { %>
            <li>
              <a href="/post/<%= p.slug %>" target="_blank"><%= p.title %></a>
              <span class="text-small text-muted"><%= p.views %> views</span>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </section>
  </div>
</div>
</body>
</html>

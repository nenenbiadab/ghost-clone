<%- include('_nav', { navActive: 'app-passwords' }) %>

<section class="admin-wrap">
  <h1>Application Passwords</h1>
  <p class="muted">Gunakan key ini untuk Basic Auth endpoint API (contoh Tampermonkey posting otomatis).</p>

  <% if (flashPassword) { %>
    <div style="padding:12px 14px;border:1px solid #22c55e;background:#ecfdf5;color:#166534;border-radius:8px;margin:14px 0;">
      <strong>Key baru (simpan sekarang, hanya tampil sekali):</strong>
      <code style="display:block;margin-top:8px;word-break:break-all;"><%= flashPassword %></code>
    </div>
  <% } %>

  <form action="/admin/app-passwords/create" method="post" style="display:flex;gap:10px;align-items:center;margin:18px 0;">
    <input
      type="text"
      name="name"
      placeholder="Nama key (contoh: Tampermonkey JKForum)"
      style="flex:1;padding:10px 12px;border:1px solid #d1d5db;border-radius:8px;"
      required
    >
    <button type="submit" style="padding:10px 14px;border:none;border-radius:8px;background:#111827;color:#fff;cursor:pointer;">
      + Generate Key
    </button>
  </form>

  <div style="overflow:auto;">
    <table style="width:100%;border-collapse:collapse;">
      <thead>
        <tr>
          <th style="text-align:left;padding:10px;border-bottom:1px solid #e5e7eb;">Name</th>
          <th style="text-align:left;padding:10px;border-bottom:1px solid #e5e7eb;">Created</th>
          <th style="text-align:left;padding:10px;border-bottom:1px solid #e5e7eb;">Last Used</th>
          <th style="text-align:left;padding:10px;border-bottom:1px solid #e5e7eb;">Status</th>
          <th style="text-align:right;padding:10px;border-bottom:1px solid #e5e7eb;">Action</th>
        </tr>
      </thead>
      <tbody>
        <% if (!keys || !keys.length) { %>
          <tr>
            <td colspan="5" style="padding:14px;color:#6b7280;">Belum ada application password.</td>
          </tr>
        <% } %>

        <% (keys || []).forEach(k => { %>
          <tr>
            <td style="padding:10px;border-bottom:1px solid #f3f4f6;"><%= k.name %></td>
            <td style="padding:10px;border-bottom:1px solid #f3f4f6;"><%= k.created_at ? new Date(k.created_at).toLocaleString('id-ID') : '-' %></td>
            <td style="padding:10px;border-bottom:1px solid #f3f4f6;"><%= k.last_used_at ? new Date(k.last_used_at).toLocaleString('id-ID') : '-' %></td>
            <td style="padding:10px;border-bottom:1px solid #f3f4f6;">
              <% if (k.revoked_at) { %>
                <span style="color:#991b1b;background:#fee2e2;padding:4px 8px;border-radius:999px;">Revoked</span>
              <% } else { %>
                <span style="color:#065f46;background:#d1fae5;padding:4px 8px;border-radius:999px;">Active</span>
              <% } %>
            </td>
            <td style="padding:10px;border-bottom:1px solid #f3f4f6;text-align:right;">
              <% if (!k.revoked_at) { %>
                <form action="/admin/app-passwords/<%= k.id %>/revoke" method="post" style="display:inline;">
                  <button type="submit" style="padding:8px 10px;border:1px solid #ef4444;color:#ef4444;background:#fff;border-radius:8px;cursor:pointer;">
                    Revoke
                  </button>
                </form>
              <% } else { %>
                <span style="color:#9ca3af;">-</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

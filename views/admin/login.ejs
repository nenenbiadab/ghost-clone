<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Admin Login — <%= site.site_title %></title>
<link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="auth-wrap">
  <div class="auth-box">
    <h1>🔐 Sign In</h1>
    <p class="subtitle">Welcome back to <strong><%= site.site_title %></strong></p>

    <% if (error) { %>
      <div class="alert error"><%= error %></div>
    <% } %>

    <form action="/admin/login" method="POST">
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" value="<%= email || '' %>" required autofocus>
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" required>
      </div>
      <button type="submit" class="btn btn-primary">Sign In</button>
    </form>

    <p class="auth-footer"><a href="/">← Back to site</a></p>
  </div>
</div>
</body>
</html>

<%- include('_header') %>

<header style="text-align:center; margin-bottom:48px; padding-bottom:32px; border-bottom:1px solid var(--border)">
  <div class="eyebrow" style="color:var(--accent); font-size:0.8rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; margin-bottom:12px">Tag</div>
  <h1 style="font-size:2.5rem; letter-spacing:-0.02em; margin-bottom:8px">#<%= tag.name %></h1>
  <p class="text-muted"><%= posts.length %> post<%= posts.length !== 1 ? 's' : '' %></p>
</header>

<% if (posts.length === 0) { %>
  <div class="empty">
    <h2>Belum ada post dengan tag ini.</h2>
  </div>
<% } else { %>
  <div class="post-grid">
    <% posts.forEach(p => { %>
      <article class="post-card">
        <a href="/post/<%= p.slug %>" class="thumb">
          <img src="<%= p.feature_image %>" alt="<%= p.title %>" loading="lazy">
        </a>
        <h3><a href="/post/<%= p.slug %>"><%= p.title %></a></h3>
        <% if (p.excerpt) { %><p class="excerpt"><%= p.excerpt %></p><% } %>
        <div class="post-meta">
          <span><%= p.formattedDate %></span>
          <span>·</span>
          <span><%= p.readTime %> min</span>
        </div>
      </article>
    <% }) %>
  </div>
<% } %>

<%- include('_footer') %>

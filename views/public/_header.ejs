<!DOCTYPE html>
<html lang="id" data-theme="<%= theme %>">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title><%= typeof pageTitle !== 'undefined' && pageTitle ? pageTitle : site.site_title %></title>
<meta name="description" content="<%= typeof pageDescription !== 'undefined' ? (pageDescription || '') : (site.site_description || '') %>">
<% if (typeof canonicalUrl !== 'undefined') { %><link rel="canonical" href="<%= canonicalUrl %>"><% } %>
<link rel="alternate" type="application/rss+xml" title="<%= site.site_title %> RSS" href="/rss.xml">
<link rel="stylesheet" href="/css/ghost.css">
<style>:root { --accent: <%= accentColor %>; }</style>

<meta property="og:title" content="<%= typeof pageTitle !== 'undefined' && pageTitle ? pageTitle : site.site_title %>">
<meta property="og:description" content="<%= typeof pageDescription !== 'undefined' ? (pageDescription || '') : (site.site_description || '') %>">
<meta property="og:type" content="<%= typeof post !== 'undefined' && post ? 'article' : 'website' %>">
<meta property="og:url" content="<%= typeof canonicalUrl !== 'undefined' ? canonicalUrl : siteUrl %>">
<% if (typeof post !== 'undefined' && post && post.feature_image) { %>
<meta property="og:image" content="<%= post.feature_image %>">
<% } %>
<meta name="twitter:card" content="summary_large_image">
</head>
<body data-theme="<%= theme %>">

<div class="airo-layout">
  <aside class="sidebar">
    <!-- Logo -->
    <div class="sidebar-logo">
      <div class="logo-hexagon">A</div>
      <div class="logo-text">Airo</div>
    </div>
    
    <!-- Navigation -->
    <nav class="sidebar-nav">
      <a href="/" class="nav-item active">
        <span>🏠</span> Home
      </a>
      <a href="#" class="nav-item">
        <span>📄</span> Classic Post
      </a>
      <a href="#" class="nav-item">
        <span>📐</span> Fullwidth Post
      </a>
      <a href="/tag" class="nav-item">
        <span>🏷️</span> Tag
      </a>
      <a href="#" class="nav-item">
        <span>👤</span> Author
      </a>
      <a href="#" class="nav-item">
        <span>⭐</span> Features
      </a>
      <a href="#" class="nav-item">
        <span>📡</span> Subscribe
      </a>
    </nav>
    
    <!-- Theme toggle -->
    <button id="theme-toggle" class="theme-toggle" title="Toggle theme">
      <%= theme === 'dark' ? '☀️' : '🌙' %>
    </button>
    
    <!-- Search -->
    <form class="sidebar-search" action="/" method="get">
      <input type="search" name="q" placeholder="Enter your search..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
    </form>
    
    <!-- Footer -->
    <div class="sidebar-footer">
      <div>Airo © 2024</div>
      <div>Published with Ghost</div>
    </div>
    
    <% if (currentUser) { %>
      <a href="/admin" class="admin-link sidebar-admin">Admin</a>
    <% } else { %>
      <a href="/admin/login" class="admin-link sidebar-admin">Login</a>
    <% } %>
  </aside>
  
  <main class="main-content">

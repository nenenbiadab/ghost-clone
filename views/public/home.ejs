<%- include('_header') %>

<% if (featured) { %>
  <section class="hero">
    <a href="/post/<%= featured.slug %>" class="hero-image">
      <img src="<%= featured.feature_image %>" alt="<%= featured.title %>" loading="lazy">
    </a>
    <div class="hero-content">
      <div class="eyebrow">⭐ Featured</div>
      <h2><a href="/post/<%= featured.slug %>"><%= featured.title %></a></h2>
      <p class="excerpt"><%= featured.excerpt %></p>
      <div class="post-meta">
        <span><%= featured.formattedDate %></span>
        <span>·</span>
        <span><%= featured.readTime %> min read</span>
      </div>
    </div>
  </section>
<% } %>

<% if (searchQuery) { %>
  <h2 class="section-title">Hasil pencarian untuk "<%= searchQuery %>"</h2>
<% } else { %>
  <h2 class="section-title">Recent Articles</h2>
<% } %>

<% if (posts.length === 0) { %>
  <div class="empty">
    <h2>Belum ada tulisan.</h2>
    <p>Stay tuned — tulisan pertama akan segera hadir!</p>
    <% if (currentUser) { %>
      <p style="margin-top:20px"><a class="admin-link" href="/admin/posts/new">✍️ Tulis post pertama</a></p>
    <% } %>
  </div>
<% } else { %>
  <div class="post-grid airo-post-grid">
    <% posts.forEach(p => { %>
      <article class="post-card airo-card elevated">
        <a href="/post/<%= p.slug %>" class="thumb">
          <img src="<%= p.feature_image %>" alt="<%= p.title %>" loading="lazy">
          <span class="card-tag">• <%= (p.tags && p.tags.length) ? p.tags[0].name.toUpperCase() : 'NEWS' %></span>
        </a>
        <div class="airo-card-body">
          <div class="card-date">📅 <%= p.formattedDate %></div>
          <h3><a href="/post/<%= p.slug %>"><%= p.title %></a></h3>
          <div class="card-bottom">
            <div class="card-author">
              <div class="author-avatar"><%= (site.site_title || 'G').charAt(0).toUpperCase() %></div>
              <span><%= site.site_title %></span>
            </div>
            <div class="card-reads">💬 <%= p.readTime %></div>
          </div>
          <a href="/post/<%= p.slug %>" class="read-more-btn">READ MORE</a>
        </div>
      </article>
    <% }) %>
  </div>
<% } %>

<% if (totalPages > 1) { %>
  <nav class="pagination" aria-label="Pagination">
    <% if (page > 1) { %>
      <a href="?<%= searchQuery ? 'q=' + encodeURIComponent(searchQuery) + '&' : '' %>page=<%= page - 1 %>">← Prev</a>
    <% } %>
    <% for (let i = 1; i <= totalPages; i++) { %>
      <% if (i === page) { %>
        <span class="active"><%= i %></span>
      <% } else { %>
        <a href="?<%= searchQuery ? 'q=' + encodeURIComponent(searchQuery) + '&' : '' %>page=<%= i %>"><%= i %></a>
      <% } %>
    <% } %>
    <% if (page < totalPages) { %>
      <a href="?<%= searchQuery ? 'q=' + encodeURIComponent(searchQuery) + '&' : '' %>page=<%= page + 1 %>">Next →</a>
    <% } %>
  </nav>
<% } %>

<% if (tags && tags.length) { %>
  <section class="tag-cloud" aria-label="Popular tags">
    <% tags.forEach(t => { %>
      <a class="tag-chip" href="/tag/<%= t.slug %>">#<%= t.name %> <span style="opacity:.6;margin-left:4px;"><%= t.count %></span></a>
    <% }) %>
  </section>
<% } %>

<%- include('_footer') %>

# ==========================================
# Ghost Clone — Environment Variables
# Copy file ini ke .env lalu isi nilai yg benar
# ==========================================

# Server
PORT=3000
NODE_ENV=production

# Session (ganti dengan random string panjang, min 32 char)
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=ganti-dengan-random-string-sangat-panjang-dan-acak-min-32-karakter

# Database MySQL (dari Hostinger)
DB_HOST=localhost
DB_PORT=3306
DB_USER=u563981535_iexist
DB_PASSWORD=ganti_password_db_anda
DB_NAME=u563981535_iexist

# Site info (muncul di meta tags, RSS, dll)
SITE_URL=https://iexist24.com
SITE_TITLE=iExist
SITE_DESCRIPTION=Microblog personal — catatan, ide, cerita

# Theme
ACCENT_COLOR=#ff3b3b

# Opsional: matikan setup route setelah selesai setup (true/false)
# Kalau false/unset, route /setup otomatis nonaktif kalau sudah ada user
DISABLE_SETUP=false
